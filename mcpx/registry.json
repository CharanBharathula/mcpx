{
  "version": "1.0.0",
  "servers": [
    {
      "name": "github",
      "description": "GitHub API integration - manage repos, issues, PRs, files, and more",
      "package": "@modelcontextprotocol/server-github",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": [
        {
          "name": "GITHUB_PERSONAL_ACCESS_TOKEN",
          "description": "GitHub Personal Access Token with repo access",
          "required": true
        }
      ],
      "arg_prompts": [],
      "tags": ["github", "git", "vcs", "code", "api"],
      "homepage": "https://github.com/modelcontextprotocol/servers/tree/main/src/github"
    },
    {
      "name": "filesystem",
      "description": "Secure file system access with configurable allowed directories",
      "package": "@modelcontextprotocol/server-filesystem",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "{allowed_dir}"],
      "env": [],
      "arg_prompts": [
        {
          "name": "allowed_dir",
          "description": "Directory path to allow filesystem access (e.g. C:\\Users\\you\\Documents or /home/user)",
          "placeholder": "{allowed_dir}",
          "required": true
        }
      ],
      "tags": ["filesystem", "files", "local"],
      "homepage": "https://github.com/modelcontextprotocol/servers/tree/main/src/filesystem"
    },
